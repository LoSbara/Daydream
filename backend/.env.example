# ═══════════════════════════════════════════════════════════════
# Daydream — Variabili d'ambiente backend
# Copia questo file in .env e compila i valori reali.
# NON committare .env nel repository (già in .gitignore).
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
PORT=8080
ENV=development

# ── SurrealDB ───────────────────────────────────────────────────
# In Docker usa: ws://surrealdb:8000/rpc
# In sviluppo locale usa: ws://localhost:8000/rpc
SURREAL_URL=ws://localhost:8000/rpc
SURREAL_NS=daydream
SURREAL_DB=daydream
SURREAL_USER=root
SURREAL_PASS=root

# ── JWT ─────────────────────────────────────────────────────────
# Genera valori sicuri con: openssl rand -hex 64
JWT_ACCESS_SECRET=cambia_questo_con_64_byte_hex_casuali
JWT_REFRESH_SECRET=cambia_questo_con_altri_64_byte_hex_casuali
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ── LLM Provider ────────────────────────────────────────────────
# LLM_PROVIDER seleziona il provider:
#   openai-compat (default) → usa LLM_BASE_URL + LLM_API_KEY + LLM_MODEL
#   anthropic               → usa solo LLM_API_KEY + LLM_MODEL (URL fisso)
#
# Esempi per openai-compat:
#   DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1   LLM_MODEL=deepseek-chat
#   Groq:      LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.3-70b-versatile
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1     LLM_MODEL=gpt-4o
#
# Esempi per anthropic:
#   LLM_MODEL=claude-sonnet-4-6
LLM_PROVIDER=openai-compat
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=inserisci_la_tua_api_key
LLM_MODEL=deepseek-chat

# ── Logging ─────────────────────────────────────────────────────
# text = leggibile in dev | json = machine-readable in prod/Docker
LOG_FORMAT=text

# ── Embedding + RAG ─────────────────────────────────────────────
# Disabilitato di default. Il gioco funziona completamente senza.
# DeepSeek NON supporta embedding — usa OpenAI o un provider compatibile.
EMBED_ENABLED=false
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=inserisci_la_tua_api_key_embedding
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=1536
